{
  "name": "research-agent",
  "version": "1.0.0",
  "description": "AI-powered research agent with web search, content scraping, and multi-source synthesis",
  "author": "Agent Platform",
  "license": "MIT",
  "tags": ["research", "web-search", "analysis", "scraping", "information-gathering"],

  "capabilities": {
    "tools": ["web-search", "web-scrape", "http-request"],
    "useCases": [
      "market-research",
      "competitor-analysis",
      "fact-checking",
      "academic-research",
      "due-diligence"
    ]
  },

  "runtime": {
    "entry": "runtime/agent.ts",
    "executable": true,
    "description": "Use with 'agent run research-agent' for instant execution"
  },

  "templates": {
    "frameworks": ["langchain", "crewai", "raw"],
    "languages": ["python", "typescript"],

    "variants": {
      "langchain-python": {
        "path": "templates/langchain-python",
        "language": "python",
        "framework": "langchain",
        "description": "LangChain-based research agent in Python",
        "dependencies": {
          "python": ">=3.9",
          "packages": [
            "langchain>=0.1.0",
            "langchain-openai>=0.0.5",
            "langchain-anthropic>=0.1.0",
            "requests>=2.31.0",
            "beautifulsoup4>=4.12.0",
            "python-dotenv>=1.0.0"
          ]
        },
        "files": {
          "agent": "{{agent_name}}.py",
          "tools": "tools/",
          "prompts": "prompts.py",
          "example": "example.py",
          "readme": "README.md",
          "requirements": "requirements.txt"
        }
      },

      "langchain-typescript": {
        "path": "templates/langchain-typescript",
        "language": "typescript",
        "framework": "langchain",
        "description": "LangChain-based research agent in TypeScript",
        "dependencies": {
          "node": ">=18",
          "packages": {
            "langchain": "^0.1.0",
            "@langchain/openai": "^0.0.19",
            "@langchain/anthropic": "^0.1.0",
            "axios": "^1.6.5",
            "cheerio": "^1.0.0-rc.12",
            "dotenv": "^16.4.0"
          }
        },
        "files": {
          "agent": "{{agentName}}.ts",
          "tools": "tools/",
          "prompts": "prompts.ts",
          "example": "example.ts",
          "readme": "README.md",
          "package": "package.json"
        }
      },

      "crewai": {
        "path": "templates/crewai",
        "language": "python",
        "framework": "crewai",
        "description": "CrewAI multi-agent research crew",
        "dependencies": {
          "python": ">=3.10",
          "packages": [
            "crewai>=0.28.0",
            "crewai-tools>=0.1.6",
            "langchain-openai>=0.0.5",
            "langchain-anthropic>=0.1.0",
            "python-dotenv>=1.0.0",
            "requests>=2.31.0"
          ]
        },
        "files": {
          "agent": "{{agent_name}}_crew.py",
          "example": "example.py",
          "readme": "README.md",
          "requirements": "requirements.txt"
        }
      },

      "raw-python": {
        "path": "templates/raw-python",
        "language": "python",
        "framework": "raw",
        "description": "Framework-agnostic Python research agent with direct API calls",
        "dependencies": {
          "python": ">=3.9",
          "packages": [
            "requests>=2.31.0",
            "python-dotenv>=1.0.0"
          ]
        },
        "files": {
          "agent": "{{agent_name}}.py",
          "example": "example.py",
          "readme": "README.md",
          "requirements": "requirements.txt"
        }
      }
    }
  },

  "examples": [
    {
      "title": "Market Research",
      "description": "Research competitors in a specific market",
      "input": "Research the top 5 AI coding assistants in 2026",
      "expectedOutput": "Comprehensive research report with competitor analysis, features, and market positioning"
    },
    {
      "title": "Fact Checking",
      "description": "Verify claims with multiple web sources",
      "input": "Verify: 'Python is the most popular programming language in 2026'",
      "expectedOutput": "Analysis with supporting evidence from multiple sources"
    },
    {
      "title": "Academic Research",
      "description": "Gather information on academic topics",
      "input": "Research recent breakthroughs in quantum computing",
      "expectedOutput": "Detailed report with citations and key findings"
    }
  ]
}
