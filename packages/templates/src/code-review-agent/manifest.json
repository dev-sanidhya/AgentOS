{
  "name": "code-review-agent",
  "version": "1.0.0", 
  "description": "An intelligent code review agent that analyzes code quality, security vulnerabilities, and best practices",
  "category": "analysis",
  "tags": ["code-review", "security", "quality", "static-analysis", "best-practices"],
  "author": "Agent Platform Team",
  "license": "MIT",
  "templates": {
    "variants": {
      "langchain-python": {
        "path": "templates/langchain-python",
        "language": "python",
        "framework": "langchain",
        "description": "LangChain-based code review agent using Python",
        "dependencies": {
          "python": ">=3.9",
          "packages": [
            "langchain>=0.1.0",
            "langchain-openai>=0.0.5", 
            "langchain-anthropic>=0.1.0",
            "python-dotenv>=1.0.0",
            "requests>=2.31.0"
          ]
        }
      },
      "langchain-typescript": {
        "path": "templates/langchain-typescript",
        "language": "typescript",
        "framework": "langchain", 
        "description": "LangChain-based code review agent using TypeScript",
        "dependencies": {
          "node": ">=18.0.0",
          "packages": [
            "@langchain/core@^0.1.0",
            "@langchain/openai@^0.0.5",
            "@langchain/anthropic@^0.1.0", 
            "langchain@^0.1.0",
            "dotenv@^16.0.0",
            "zod@^3.22.0"
          ]
        }
      },
      "crewai": {
        "path": "templates/crewai",
        "language": "python",
        "framework": "crewai",
        "description": "Multi-agent code review system using CrewAI",
        "dependencies": {
          "python": ">=3.9",
          "packages": [
            "crewai>=0.28.0",
            "crewai-tools>=0.1.0",
            "openai>=1.0.0",
            "python-dotenv>=1.0.0"
          ]
        }
      },
      "raw-python": {
        "path": "templates/raw-python", 
        "language": "python",
        "framework": "none",
        "description": "Pure Python code review agent with direct API calls",
        "dependencies": {
          "python": ">=3.9",
          "packages": [
            "requests>=2.31.0",
            "openai>=1.0.0",
            "anthropic>=0.7.0",
            "python-dotenv>=1.0.0"
          ]
        }
      }
    }
  }
}
