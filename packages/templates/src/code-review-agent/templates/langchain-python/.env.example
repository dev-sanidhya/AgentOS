# =============================================================================
# Code Review Agent Configuration
# =============================================================================

# LLM API Keys (required - choose one or both for redundancy)
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# =============================================================================
# Agent Configuration
# =============================================================================

# Default model provider: "openai" or "anthropic"
DEFAULT_MODEL_PROVIDER=openai

# Model-specific settings
OPENAI_MODEL_NAME=gpt-4-turbo-preview
ANTHROPIC_MODEL_NAME=claude-3-sonnet-20240229

# Agent behavior settings
AGENT_TEMPERATURE=0.1
AGENT_MAX_TOKENS=4000
AGENT_MAX_ITERATIONS=10
AGENT_VERBOSE=false

# =============================================================================
# Analysis Configuration
# =============================================================================

# Security scanning settings
SECURITY_SCAN_ENABLED=true
SECURITY_CRITICAL_THRESHOLD=7
SECURITY_HIGH_THRESHOLD=5

# Code quality thresholds
QUALITY_SCORE_THRESHOLD=7
COMPLEXITY_THRESHOLD=10
LINE_LENGTH_THRESHOLD=120
FUNCTION_LENGTH_THRESHOLD=50

# File size limits (in bytes)
MAX_FILE_SIZE=51200
MAX_TOTAL_ANALYSIS_SIZE=1048576

# =============================================================================
# Review Scope Configuration
# =============================================================================

# File extensions to analyze (comma-separated)
SUPPORTED_EXTENSIONS=.py,.js,.ts,.tsx,.jsx,.java,.go,.rs,.cpp,.c,.h,.hpp,.cs,.php,.rb

# Directories to exclude (comma-separated)
EXCLUDE_DIRECTORIES=node_modules,.git,__pycache__,.venv,venv,build,dist,.pytest_cache

# Files to exclude (comma-separated patterns)
EXCLUDE_FILES=*.min.js,*.bundle.js,*.pyc,*.pyo,*.pyd

# =============================================================================
# Security Configuration
# =============================================================================

# Enable specific security checks
CHECK_SQL_INJECTION=true
CHECK_XSS_VULNERABILITIES=true
CHECK_HARDCODED_SECRETS=true
CHECK_CRYPTO_ISSUES=true
CHECK_INPUT_VALIDATION=true
CHECK_AUTH_ISSUES=true

# Secret detection sensitivity (1-10, 10 being most sensitive)
SECRET_DETECTION_SENSITIVITY=7

# =============================================================================
# Performance Settings
# =============================================================================

# Request timeout (seconds)
REQUEST_TIMEOUT=120

# Concurrent analysis limit
MAX_CONCURRENT_FILES=5

# Cache settings
ENABLE_CACHE=true
CACHE_EXPIRY_HOURS=24

# =============================================================================
# Output Configuration
# =============================================================================

# Report format: "detailed", "summary", "json"
DEFAULT_REPORT_FORMAT=detailed

# Include positive feedback in reports
INCLUDE_POSITIVE_FEEDBACK=true

# Generate HTML reports
GENERATE_HTML_REPORTS=false

# Report output directory
REPORTS_OUTPUT_DIR=./reports

# =============================================================================
# Git Integration
# =============================================================================

# Default base branch for git diff analysis
DEFAULT_BASE_BRANCH=main

# Include git metadata in analysis
INCLUDE_GIT_METADATA=true

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log to file
LOG_TO_FILE=false
LOG_FILE_PATH=./logs/code_review_agent.log

# =============================================================================
# Integration Settings
# =============================================================================

# GitHub integration (optional)
# GITHUB_TOKEN=ghp_your_github_token_here
# GITHUB_ORG=your-organization
# GITHUB_REPO=your-repository

# GitLab integration (optional)
# GITLAB_TOKEN=glpat-your-gitlab-token-here
# GITLAB_URL=https://gitlab.com

# Slack notifications (optional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SLACK_CHANNEL=#code-reviews

# =============================================================================
# Development Settings
# =============================================================================

# Enable development mode (more verbose logging, debugging features)
DEV_MODE=false

# Enable experimental features
ENABLE_EXPERIMENTAL_FEATURES=false

# Custom rules file path
CUSTOM_RULES_FILE=./config/custom_rules.json