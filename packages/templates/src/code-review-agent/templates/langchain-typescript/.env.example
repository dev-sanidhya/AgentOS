# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=4000

# Anthropic Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-sonnet-20240229
ANTHROPIC_TEMPERATURE=0.1
ANTHROPIC_MAX_TOKENS=4000

# Default Model Provider (openai or anthropic)
DEFAULT_MODEL_PROVIDER=openai

# Code Review Configuration
INCLUDE_SECURITY_SCAN=true
INCLUDE_PERFORMANCE_ANALYSIS=true
STRICT_MODE=false
LANGUAGE_SPECIFIC_RULES=true

# Output Configuration
VERBOSE_OUTPUT=false
ENABLE_DEBUG_LOGGING=false

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=60
MAX_CONCURRENT_REVIEWS=5

# Security Scanner Configuration
SECURITY_SCAN_TIMEOUT=30000
ENABLE_CWE_MAPPING=true
ENABLE_OWASP_MAPPING=true

# File Analysis Configuration
MAX_FILE_SIZE_MB=10
SUPPORTED_LANGUAGES=javascript,typescript,python,java,go,rust,cpp,csharp
ENABLE_COMPLEXITY_ANALYSIS=true

# Custom Rules (comma-separated)
CUSTOM_SECURITY_RULES=
CUSTOM_QUALITY_RULES=

# Reporting Configuration
GENERATE_JSON_REPORT=true
GENERATE_HTML_REPORT=false
REPORT_OUTPUT_DIR=./reports