# {{AgentName}} CrewAI Configuration
# Copy this file to .env and fill in your actual API keys and settings

# =============================================================================
# LLM PROVIDER CONFIGURATION
# =============================================================================

# OpenAI Configuration (Default provider)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Configuration (Alternative provider)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================

# Default LLM provider to use (openai or anthropic)
DEFAULT_LLM_PROVIDER=openai

# Model parameters
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4000
LLM_REQUEST_TIMEOUT=300

# Agent behavior settings
AGENT_VERBOSE=true
AGENT_ALLOW_DELEGATION=false
AGENT_MAX_ITERATIONS=5

# =============================================================================
# CODE REVIEW CONFIGURATION
# =============================================================================

# Default scan settings
DEFAULT_SCAN_TYPE=comprehensive
DEFAULT_SEVERITY_THRESHOLD=medium
DEFAULT_INCLUDE_METRICS=true

# Security scanning settings
SECURITY_SCAN_ENABLED=true
VULNERABILITY_SCAN_ENABLED=true
SECRET_SCAN_ENABLED=true
DEPENDENCY_SCAN_ENABLED=true

# Analysis settings
COMPLEXITY_THRESHOLD_HIGH=10
COMPLEXITY_THRESHOLD_CRITICAL=20
MAX_FILE_SIZE_MB=10
MAX_LINES_TO_ANALYZE=5000

# =============================================================================
# REPORTING CONFIGURATION
# =============================================================================

# Report settings
DEFAULT_REPORT_FORMAT=json
REPORT_INCLUDE_CODE_SNIPPETS=true
REPORT_OBFUSCATE_SECRETS=true
GENERATE_HTML_REPORTS=true
GENERATE_MARKDOWN_REPORTS=true

# Output directory for reports
REPORTS_OUTPUT_DIR=./reports
REPORTS_TIMESTAMP_FORMAT=%Y%m%d_%H%M%S

# =============================================================================
# TOOL CONFIGURATION
# =============================================================================

# File analyzer settings
FILE_ANALYZER_ENABLED=true
INCLUDE_COMPLEXITY_ANALYSIS=true
INCLUDE_STRUCTURE_ANALYSIS=true
DETECT_CODE_SMELLS=true

# Security scanner settings
SECURITY_SCANNER_ENABLED=true
SCAN_FOR_SECRETS=true
SCAN_FOR_VULNERABILITIES=true
SCAN_DEPENDENCIES=true
CHECK_CRYPTO_USAGE=true

# Pattern matching settings
ENABLE_REGEX_PATTERNS=true
CASE_SENSITIVE_PATTERNS=false
MULTILINE_PATTERN_MATCHING=true

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================

# Concurrent processing
MAX_CONCURRENT_FILES=5
MAX_CONCURRENT_AGENTS=3
ENABLE_PARALLEL_PROCESSING=true

# Caching settings
ENABLE_RESULT_CACHING=false
CACHE_DIRECTORY=./.cache
CACHE_EXPIRY_HOURS=24

# Memory management
MAX_MEMORY_USAGE_MB=1024
ENABLE_GARBAGE_COLLECTION=true

# =============================================================================
# LOGGING AND DEBUGGING
# =============================================================================

# Logging configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=./logs/code_review_agent.log
LOG_MAX_SIZE_MB=50
LOG_BACKUP_COUNT=5

# Debug settings
DEBUG_MODE=false
ENABLE_DETAILED_LOGGING=false
LOG_CREWAI_INTERNALS=false
SAVE_RAW_RESPONSES=false

# =============================================================================
# INTEGRATION CONFIGURATION
# =============================================================================

# GitHub integration (optional)
# GITHUB_TOKEN=your_github_token_here
# GITHUB_REPO_OWNER=your_username
# GITHUB_REPO_NAME=your_repository

# GitLab integration (optional)
# GITLAB_TOKEN=your_gitlab_token_here
# GITLAB_PROJECT_ID=your_project_id

# Slack notifications (optional)
# SLACK_WEBHOOK_URL=your_slack_webhook_url
# SLACK_CHANNEL=#code-review

# Email notifications (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# EMAIL_FROM=code-review@yourcompany.com
# EMAIL_TO=team@yourcompany.com

# =============================================================================
# FILE PROCESSING CONFIGURATION
# =============================================================================

# File inclusion patterns (comma-separated)
INCLUDE_FILE_PATTERNS=*.py,*.js,*.ts,*.java,*.cpp,*.c,*.go,*.rs,*.rb,*.php

# File exclusion patterns (comma-separated)
EXCLUDE_FILE_PATTERNS=*.min.js,*.bundle.js,node_modules/*,venv/*,__pycache__/*,*.pyc,*.pyo

# Directory exclusion patterns (comma-separated)
EXCLUDE_DIRECTORIES=node_modules,venv,env,.git,.svn,__pycache__,.pytest_cache,build,dist

# Maximum file size for analysis (in bytes)
MAX_FILE_SIZE_BYTES=10485760

# =============================================================================
# EXTERNAL TOOL CONFIGURATION
# =============================================================================

# Bandit security scanner
BANDIT_CONFIG_FILE=./config/bandit.yaml
BANDIT_SEVERITY_LEVEL=low

# ESLint for JavaScript/TypeScript
ESLINT_CONFIG_FILE=.eslintrc.json
ESLINT_ENABLED=false

# SonarQube integration (optional)
# SONAR_HOST_URL=https://sonarcloud.io
# SONAR_TOKEN=your_sonar_token
# SONAR_PROJECT_KEY=your_project_key

# =============================================================================
# CUSTOM CONFIGURATION
# =============================================================================

# Custom security rules file
CUSTOM_SECURITY_RULES=./config/custom_security_rules.json

# Custom complexity thresholds
CUSTOM_COMPLEXITY_CONFIG=./config/complexity_config.json

# Custom report templates
CUSTOM_REPORT_TEMPLATES_DIR=./templates/reports

# Agent customization
AGENT_PERSONALITY_CONFIG=./config/agent_personalities.json

# =============================================================================
# EXPERIMENTAL FEATURES
# =============================================================================

# Enable experimental features (use with caution)
ENABLE_EXPERIMENTAL_FEATURES=false
EXPERIMENTAL_AI_SUGGESTIONS=false
EXPERIMENTAL_AUTO_FIX=false
EXPERIMENTAL_PATTERN_LEARNING=false

# =============================================================================
# LICENSE AND COMPLIANCE
# =============================================================================

# License scanning
SCAN_FOR_LICENSE_ISSUES=false
ALLOWED_LICENSES=MIT,Apache-2.0,BSD-3-Clause,ISC

# Compliance checking
ENABLE_COMPLIANCE_CHECKS=false
COMPLIANCE_FRAMEWORK=SOX,PCI-DSS,HIPAA

# =============================================================================
# NOTES
# =============================================================================

# 1. Make sure to keep your .env file secure and never commit it to version control
# 2. Use strong API keys and rotate them regularly
# 3. Adjust the configuration based on your specific needs and infrastructure
# 4. Test the configuration with a small set of files before running on large codebases
# 5. Monitor resource usage and adjust concurrency settings accordingly

# For more information, see the README.md file or documentation